---
interface Props {
  title: string;
  price: string;
  description: string;
  image?: string;
  badge?: string;
}

const { title, price, description, image, badge } = Astro.props;
import { Image as LucideImage } from 'lucide';
---

<div class="menu-card bg-angus-black rounded-2xl overflow-hidden border border-white/5 hover:border-white/10 transition-all duration-300 hover:-translate-y-2 group">
  <div class="h-48 overflow-hidden relative bg-gray-800">
    {image ? (
      <img 
        src={image} 
        alt={title} 
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <i data-lucide="image" class="w-12 h-12 text-gray-600"></i>
      </div>
    )}
    <div class="absolute top-4 right-4 bg-angus-red text-white px-3 py-1 rounded-full font-bold shadow-lg">
      {price}
    </div>
    {badge && (
      <div class="absolute top-4 left-4 bg-angus-orange text-white text-xs px-2 py-1 rounded font-bold uppercase">
        {badge}
      </div>
    )}
  </div>
  <div class="p-6">
    <h3 class="text-xl font-heading font-bold text-white mb-2 group-hover:text-angus-orange transition-colors">
      {title}
    </h3>
    <p class="text-gray-400 text-sm mb-4 line-clamp-2">
      {description}
    </p>
    <button class="w-full py-2 rounded-lg border border-white/10 text-white font-medium hover:bg-white hover:text-angus-black transition-colors">
      Agregar al pedido
    </button>
  </div>
</div>