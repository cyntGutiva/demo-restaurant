---
import { pool } from '../lib/mysql';

let menuItems = [];
let error = null;

try {
  const [rows]: any = await pool.query('SELECT * FROM menu_items ORDER BY id DESC');
  menuItems = rows;
  
} catch (e) {
  error = e.message;
  console.error("Error en BD:", e);
}

const hasItems = menuItems && menuItems.length > 0;
---
<section id="menu" class="py-24 bg-angus-dark relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-heading font-bold text-white mb-4">Nuestra Carta</h2>
      <p class="text-gray-400 max-w-2xl mx-auto">Elige tu combinación favorita. Desde pollos enteros hasta hamburguesas bañadas en cheddar.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 w-full">
      {hasItems ? (
        menuItems.map((item) => {
          // FORZAR FORMATO CHILENO: 
          // Convertimos a número por si la BD lo devuelve como string
          const precioNumerico = Number(item.price);
          const precioFormateado = new Intl.NumberFormat('es-CL', {
            style: 'currency',
            currency: 'CLP',
            minimumFractionDigits: 0
          }).format(precioNumerico);

          return (
            <div class="menu-card bg-angus-black rounded-2xl overflow-hidden border border-white/5 hover:border-white/10 transition-all duration-300 hover:-translate-y-2 group">
              <div class="h-48 overflow-hidden relative bg-gray-800">
                {item.image_url ? (
                  <img 
                    src={item.image_url} 
                    alt={item.name} 
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-zinc-900">
                    <span class="text-zinc-700 text-xs">Fried Chicken</span>
                  </div>
                )}
                
                <div class="absolute top-4 right-4 bg-angus-red text-white px-3 py-1 rounded-full font-bold shadow-lg">
                  {precioFormateado}
                </div>

                {item.category === 'Destacado' && (
                  <div class="absolute top-4 left-4 bg-angus-orange text-white text-xs px-2 py-1 rounded font-bold uppercase">
                    Popular
                  </div>
                )}
              </div>

              <div class="p-6">
                <h3 class="text-xl font-bold text-white mb-2 group-hover:text-angus-orange transition-colors">
                  {item.name}
                </h3>
                <p class="text-gray-400 text-sm mb-4 line-clamp-2">
                  {item.description}
                </p>
                <button 
                  class="add-to-cart-btn w-full py-2 rounded-lg border border-white/10 text-center text-white font-medium hover:bg-white hover:text-angus-black transition-colors"
                  data-id={item.id}
                  data-nombre={item.name}
                  data-precio={item.price}
                >
                  Agregar al pedido
                </button>
              </div>
            </div>
          );
        })
      ) : (
        <div class="col-span-full text-center py-20 border border-dashed border-white/10 rounded-2xl">
          <p class="text-gray-500">
            {error ? `Error de conexión: ${error}` : "No se encontraron productos en la base de datos."}
          </p>
        </div>
      )}
    </div>
  </div>
</section>

<script is:inline>
  document.querySelectorAll('.add-to-cart-btn').forEach(button => {
    button.addEventListener('click', () => {
      // 1. Extraemos los datos del botón primero
      const id = button.getAttribute('data-id');
      const nombre = button.getAttribute('data-nombre');
      const precioUnitario = Number(button.getAttribute('data-precio'));

      // 2. Obtenemos el carrito actual
      let cart = JSON.parse(localStorage.getItem('cart') || '[]');

      // 3. BUSCAMOS si ya existe el producto en el carrito usando el ID
      const itemExistente = cart.find(item => item.id === id);

      if (itemExistente) {
        // 4. SI EXISTE: Solo aumentamos la cantidad y recalculamos el total de esa línea
        itemExistente.qty += 1;
        itemExistente.totalPrice = itemExistente.qty * itemExistente.price;
      } else {
        // 5. SI NO EXISTE: Agregamos el objeto nuevo con qty 1
        cart.push({
          id: id,
          name: nombre,
          price: precioUnitario,
          totalPrice: precioUnitario,
          qty: 1
        });
      }

      // 6. Guardamos el carrito actualizado
      localStorage.setItem('cart', JSON.stringify(cart));

      // 7. Notificamos al Sidebar
      window.dispatchEvent(new Event('cart-updated'));
      
      if (window.openCartSidebar) {
        window.openCartSidebar();
      }
      // Feedback visual
      const originalText = button.innerText;
      button.innerText = "¡Añadido!";
      button.classList.add('bg-green-600'); // Opcional: cambio de color rápido
      
      setTimeout(() => {
        button.innerText = originalText;
        button.classList.remove('bg-green-600');
      }, 1000);
    });
  });

  window.updateQty = function(id, change) {
    let cart = JSON.parse(localStorage.getItem('cart') || '[]');
    
    // Buscamos el item por su ID
    const item = cart.find(i => i.id === id);
    
    if (item) {
      item.qty += change;

      // Si la cantidad baja de 1, eliminamos el producto del carrito
      if (item.qty <= 0) {
        cart = cart.filter(i => i.id !== id);
      } else {
        // Actualizamos el precio total de esa línea
        item.totalPrice = item.qty * item.price;
      }
      
      localStorage.setItem('cart', JSON.stringify(cart));
      
      // Re-renderizamos el sidebar para que se vean los cambios
      if (typeof renderCart === 'function') {
        renderCart();
      }
      
      // Opcional: Notificar a otros componentes
      window.dispatchEvent(new Event('cart-updated'));
    }
  };

  // Asegúrate de que tu función removeFromCart también use el ID
  window.removeFromCart = function(id) {
    let cart = JSON.parse(localStorage.getItem('cart') || '[]');
    cart = cart.filter(i => i.id !== id);
    localStorage.setItem('cart', JSON.stringify(cart));
    renderCart();
    window.dispatchEvent(new Event('cart-updated'));
  };
</script>