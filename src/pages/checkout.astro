---
import Layout from '../layouts/Layout.astro';
// Accedemos a la variable de entorno
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER;
const whatsappLink = `https://wa.me/${whatsappNumber}`;
---

<Layout title="Finalizar Pedido | Angus Chicken" showCart={false}>
  <main class="py-20 bg-black text-white px-4">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-3xl font-bold mb-8 font-heading text-center">Resumen de tu <span class="text-angus-red">Pedido</span></h1>
      
      <div id="cart-summary" class="bg-zinc-900/50 rounded-2xl border border-white/5 p-6 mb-10 space-y-4">
        </div>

      <form id="order-form" class="space-y-6 bg-zinc-900 p-8 rounded-2xl border border-white/5 shadow-2xl" data-whatsapp-link={whatsappLink}>
        <h3 class="text-xl font-bold mb-4 border-b border-white/10 pb-2">Datos de Entrega</h3>
        
        <div>
          <label class="block text-sm text-gray-400 mb-2">Nombre Completo</label>
          <input type="text" id="nombre-cliente" required class="w-full bg-black border border-white/10 p-3 rounded-lg focus:border-angus-red outline-none transition-colors">
        </div>
        
        <div>
          <label class="block text-sm text-gray-400 mb-2">Teléfono de Contacto</label>
          <input type="tel" id="telefono-cliente" placeholder="+569 1234 5678" required class="w-full bg-black border border-white/10 p-3 rounded-lg focus:border-angus-red outline-none transition-colors">
        </div>
        
        <div>
          <label class="block text-sm text-gray-400 mb-2">Dirección de Entrega</label>
          <textarea id="direccion-cliente" rows="3" required class="w-full bg-black border border-white/10 p-3 rounded-lg focus:border-angus-red outline-none transition-colors" placeholder="Calle, número, departamento o referencia..."></textarea>
        </div>

        <button type="submit" class="w-full py-4 bg-angus-red hover:bg-red-700 text-white font-bold rounded-xl transition-all shadow-lg shadow-red-900/40 uppercase tracking-wider">
          Enviar pedido por WhatsApp
        </button>
        
        <a href="/" class="block text-center text-sm text-gray-500 hover:text-white transition-colors">
          ← Volver a la carta para agregar más
        </a>
      </form>
    </div>
  </main>
</Layout>

<script>
  // Al no ser inline, este código se ejecuta una vez que el DOM está listo
  const summaryDiv = document.getElementById('cart-summary');
  const orderForm = document.getElementById('order-form') as HTMLFormElement;
  const cart = JSON.parse(localStorage.getItem('cart') || '[]');
  let totalFinal = 0;

  // 1. Renderizar Resumen
  if (summaryDiv) {
    if (cart.length === 0) {
      summaryDiv.innerHTML = `<p class="text-center py-10 text-gray-500">Carrito vacío</p>`;
      orderForm?.classList.add('opacity-50', 'pointer-events-none');
    } else {
      let htmlContent = '';
      cart.forEach(item => {
        const subtotalItem = Number(item.price) * item.qty;
        totalFinal += subtotalItem;
        htmlContent += `
          <div class="flex justify-between items-center border-b border-white/5 pb-4">
            <div class="flex flex-col">
              <div class="flex items-center gap-2">
                <span class="text-angus-red font-black text-xl italic">${item.qty}x</span>
                <span class="text-white font-bold text-lg">${item.name}</span>
              </div>
              <span class="text-gray-500 text-xs">$${Number(item.price).toLocaleString('es-CL')} c/u</span>
            </div>
            <span class="font-bold text-angus-orange">$${subtotalItem.toLocaleString('es-CL')}</span>
          </div>`;
      });
      
      htmlContent += `
        <div class="pt-4 mt-4 border-t-2 border-white/10 flex justify-between items-center text-xl font-bold">
          <span>Total a Pagar</span>
          <span class="text-angus-red font-black">$${totalFinal.toLocaleString('es-CL')}</span>
        </div>`;
      summaryDiv.innerHTML = htmlContent;
    }
  }

  // 2. Manejar Envío
  orderForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    // Obtenemos el link que pasamos desde Astro
    const whatsappBaseUrl = orderForm.getAttribute('data-whatsapp-link');
    
    const cliente = (document.getElementById('nombre-cliente') as HTMLInputElement).value;
    const telefono = (document.getElementById('telefono-cliente') as HTMLInputElement).value;
    const direccion = (document.getElementById('direccion-cliente') as HTMLTextAreaElement).value;

    const listaProductos = cart.map(item => 
      `• ${item.qty}x ${item.name} ($${(item.price * item.qty).toLocaleString('es-CL')})`
    ).join('%0A');
    
    const mensaje = `*NUEVO PEDIDO - ANGUS CHICKEN*%0A%0A` +
                   `*Cliente:* ${cliente}%0A` +
                   `*Teléfono:* ${telefono}%0A` +
                   `*Dirección:* ${direccion}%0A%0A` +
                   `*Detalle:*%0A${listaProductos}%0A%0A` +
                   `*TOTAL:* $${totalFinal.toLocaleString('es-CL')}`;

    window.open(`${whatsappBaseUrl}?text=${mensaje}`, '_blank');
  });
</script>