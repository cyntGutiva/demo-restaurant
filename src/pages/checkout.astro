---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Finalizar Pedido | Angus Chicken">
  <main class="py-20 bg-black text-white px-4">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-3xl font-bold mb-8 font-heading text-center">Resumen de tu <span class="text-angus-red">Pedido</span></h1>
      
      <div id="cart-summary" class="bg-zinc-900/50 rounded-2xl border border-white/5 p-6 mb-10 space-y-4">
        </div>

      <form id="order-form" class="space-y-6 bg-zinc-900 p-8 rounded-2xl border border-white/5 shadow-2xl">
        <h3 class="text-xl font-bold mb-4 border-b border-white/10 pb-2">Datos de Entrega</h3>
        
        <div>
          <label class="block text-sm text-gray-400 mb-2">Nombre Completo</label>
          <input type="text" id="nombre-cliente" required class="w-full bg-black border border-white/10 p-3 rounded-lg focus:border-angus-red outline-none transition-colors">
        </div>
        
        <div>
          <label class="block text-sm text-gray-400 mb-2">Teléfono de Contacto</label>
          <input type="tel" id="telefono-cliente" placeholder="+569 1234 5678" required class="w-full bg-black border border-white/10 p-3 rounded-lg focus:border-angus-red outline-none transition-colors">
        </div>
        
        <div>
          <label class="block text-sm text-gray-400 mb-2">Dirección de Entrega</label>
          <textarea id="direccion-cliente" rows="3" required class="w-full bg-black border border-white/10 p-3 rounded-lg focus:border-angus-red outline-none transition-colors" placeholder="Calle, número, departamento o referencia..."></textarea>
        </div>

        <button type="submit" class="w-full py-4 bg-angus-red hover:bg-red-700 text-white font-bold rounded-xl transition-all shadow-lg shadow-red-900/40 uppercase tracking-wider">
          Enviar pedido por WhatsApp
        </button>
        
        <a href="/" class="block text-center text-sm text-gray-500 hover:text-white transition-colors">
          ← Volver a la carta para agregar más
        </a>
      </form>
    </div>
  </main>
</Layout>

<script is:inline>
  const summaryDiv = document.getElementById('cart-summary');
  const cart = JSON.parse(localStorage.getItem('cart') || '[]');
  let totalFinal = 0;

  // 1. Renderizar el resumen con cantidades y precios
  if (cart.length === 0) {
    summaryDiv.innerHTML = `
      <div class="text-center py-10">
        <p class="text-gray-500 mb-4">Tu carrito está vacío.</p>
        <a href="/" class="text-angus-red font-bold underline">Volver al menú</a>
      </div>
    `;
    document.getElementById('order-form').classList.add('opacity-50', 'pointer-events-none');
  } else {
    let htmlContent = '';
    
    cart.forEach(item => {
      const subtotalItem = Number(item.price) * item.qty;
      totalFinal += subtotalItem;
      
      htmlContent += `
        <div class="flex justify-between items-center border-white/5 pb-4 last:border-0 last:pb-0">
        <div class="flex flex-col">
          <div class="flex items-center gap-2">
            <span class="text-angus-red font-black text-xl italic">${item.qty}x</span>
            <span class="text-white font-bold text-lg">${item.name}</span>
          </div>
          
          <span class="text-gray-500 text-xs ml-1">
            $${Number(item.price).toLocaleString('es-CL')} c/u
          </span>
        </div>

        <span class="font-bold text-angus-orange text-md">
          $${subtotalItem.toLocaleString('es-CL')}
        </span>
      </div>
      `;
    });

    htmlContent += `
      <div class="pt-4 mt-4 border-t-2 border-white/10 flex justify-between items-center">
        <span class="text-xl font-bold">Total a Pagar</span>
        <span class="font-bold text-angus-orange">$${totalFinal.toLocaleString('es-CL')}</span>
      </div>
    `;
    
    summaryDiv.innerHTML = htmlContent;
  }

  // 2. Manejar el envío por WhatsApp
  document.getElementById('order-form').addEventListener('submit', (e) => {
    e.preventDefault();
    
    const cliente = document.getElementById('nombre-cliente').value;
    const telefono = document.getElementById('telefono-cliente').value;
    const direccion = document.getElementById('direccion-cliente').value;

    // Formatear lista detallada para WhatsApp
    const listaProductos = cart.map(item => 
      `• ${item.qty}x ${item.name} ($${(item.price * item.qty).toLocaleString('es-CL')})`
    ).join('%0A');
    
    const totalTexto = `$${totalFinal.toLocaleString('es-CL')}`;
    
    const mensaje = `*NUEVO PEDIDO - ANGUS CHICKEN*%0A%0A` +
                   `*Cliente:* ${cliente}%0A` +
                   `*Teléfono:* ${telefono}%0A` +
                   `*Dirección:* ${direccion}%0A%0A` +
                   `*Detalle del Pedido:*%0A${listaProductos}%0A%0A` +
                   `*TOTAL A PAGAR:* ${totalTexto}%0A%0A` +
                   `_Por favor, confirma la recepción de este pedido._`;

    // Reemplaza con el número de Angus Chicken (formato: 569XXXXXXXX)
    const whatsappUrl = `https://wa.me/569XXXXXXXX?text=${mensaje}`;
    
    window.open(whatsappUrl, '_blank');
    
    // Opcional: Vaciar carrito tras el pedido exitoso
    // localStorage.removeItem('cart');
  });
</script>